# ============================================================================
# VidScrib Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control!

# Groq API Configuration (for Whisper transcription)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Configuration (for AI processing)
# Get your API keys from: https://aistudio.google.com/app/apikey
# You can add multiple keys separated by commas for rate limit rotation
GEMINI_API_KEY_1=your_gemini_api_key_1_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GEMINI_API_KEY_3=your_gemini_api_key_3_here
GEMINI_API_KEY_4=your_gemini_api_key_4_here
GEMINI_API_KEY_5=your_gemini_api_key_5_here
GEMINI_API_KEY=your_gemini_api_key

# Flask Configuration
FLASK_SECRET_KEY=your_random_secret_key_here_change_this_in_production

# Optional: Uncomment and configure if needed
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5001
# FLASK_DEBUG=True
